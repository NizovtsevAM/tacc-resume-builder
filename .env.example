# TACC API credentials and date range
TACC_EMAIL=your_email@example.com
TACC_PASSWORD=your_password
TACC_START_DATE=1/1/2011
TACC_END_DATE=6/30/2026

# Personal info - for resume
FIRST_NAME=John
LAST_NAME=Doe
TITLE=Your Job Title
EMAIL=your.email@example.com
LINKEDIN=linkedin.com/in/yourprofile
PHONE=+1 (555) 123-4567
LOCATION=Your City, Country

# Resume filtering
MINIMUM_PROJECT_DURATION_DAYS=30

# Filtering lists - Add values separated by commas
ENV_EXCLUDE_CUSTOMERS=vacation,training,sick,sickness,bench,holiday,day off,break,leave,pto,personal time,admin,office,meeting,conference,workshop,seminar,interview,recruitment
ENV_TECHNOLOGY_BLACKLIST=template,extraction,data scraping,ui,db,it,enum,ie,dropbox,link,file,office,admin,support,meeting

# Template (modern, classic, minimalist, or creative)
RESUME_TEMPLATE=modern

# LLM settings (optional but recommended)
USE_LLM=true
LLM_URL=http://127.0.0.1:1234
LLM_MODEL=google/gemma-4-e4b
LLM_PROVIDER=lmstudio
